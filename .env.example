# Public URL of the APK to download. Point this at your AWS S3 / CloudFront URL.
# When unset, the download button falls back to the S3 release URL in lib/config.ts
NEXT_PUBLIC_APK_URL=https://letscrackit-files.s3.ap-south-1.amazonaws.com/letscrackit-release.apk

# Optional cosmetic fields shown in the UI
NEXT_PUBLIC_APP_VERSION=2.11 (13)
NEXT_PUBLIC_APK_SIZE=~24 MB
